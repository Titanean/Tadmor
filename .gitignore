# Release signing — NEVER commit. Lose this keystore and you can never
# publish a signed update; users on the old version would be unable to
# install the new one. Back it up out-of-band (password manager, etc).
*.jks
*.keystore
keystore.properties

# Release APK output (Android Studio's "Generate Signed APK" default
# destination). The APK belongs in GitHub Releases, not in the repo.
app/release/
*.apk
